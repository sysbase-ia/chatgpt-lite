# Duplicate this file and rename as '.env.local' for local development.
# You must obtain OpenAI or Azure OpenAI credentials to run this application.
# For detailed instructions on using these variables, visit:
# https://github.com/blrchen/chatgpt-lite#environment-variables

# -----------------------------------------------------------------------------
# OpenAI API credentials (required for using the OpenAI API):
# Sign up at https://openai.com/api/ to get your API key.
# -----------------------------------------------------------------------------
OPENAI_API_KEY= # <-- Insert your OpenAI API key here
OPENAI_API_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Sysbase Control-Plane bridge (optional, overrides direct provider calls):
# When CONTROL_PLANE_CHAT_URL is set, /api/chat proxies through sysbase control-plane.
# -----------------------------------------------------------------------------
CONTROL_PLANE_CHAT_URL=
CONTROL_PLANE_CHAT_STREAM_URL=
CONTROL_PLANE_CHAT_TOKEN=
CONTROL_PLANE_AGENT_ID=diana
CONTROL_PLANE_THINK=off

# Scope-based authorization (optional):
# Comma or space separated scopes. If omitted, defaults are:
# - WEB_CHAT_REQUIRED_CHAT_SCOPES=chat.write
# - WEB_CHAT_REQUIRED_TOPOLOGY_READ_SCOPES=topology.read
# - WEB_CHAT_REQUIRED_TOPOLOGY_WRITE_SCOPES=topology.read
WEB_CHAT_REQUIRED_CHAT_SCOPES=
WEB_CHAT_REQUIRED_TOPOLOGY_READ_SCOPES=
WEB_CHAT_REQUIRED_TOPOLOGY_WRITE_SCOPES=

# Profile-level authorization (optional):
# - Scope mode:
#   off      -> disable profile filtering
#   optional -> enforce only if token includes profile scopes (default)
#   strict   -> always require profile scopes
# - Scope examples:
#   profile.all
#   profile.efra
#   profile.andrea
WEB_CHAT_PROFILE_SCOPE_MODE=optional
WEB_CHAT_PROFILE_SCOPE_PREFIX=profile.
WEB_CHAT_PROFILE_ALL_SCOPES=profile.all profile.*
WEB_CHAT_PROFILE_SELF_SCOPES=profile.self
WEB_CHAT_PROFILE_AGENT_MAP_FILE=/opt/sysbase/components/openclaw/config/profile_agents.map
WEB_CHAT_PROFILE_AGENT_MAP_CACHE_SECONDS=15

# -----------------------------------------------------------------------------
# Upload storage (optional):
# Large files are stored server-side and sent as local file references to chat.
# Default: /tmp/sysbase-web-chat/uploads
# -----------------------------------------------------------------------------
WEB_CHAT_UPLOAD_DIR=

# -----------------------------------------------------------------------------
# Azure OpenAI API credentials (required for using the Azure OpenAI API with ai-sdk):
# Sign up at https://azure.microsoft.com/en-us/services/cognitive-services/openai/ for Azure OpenAI credentials.
# Uncomment the following lines and insert your credentials if you're using Azure OpenAI.
# -----------------------------------------------------------------------------
# AZURE_OPENAI_RESOURCE_NAME= # <-- Insert your Azure OpenAI resource name here (e.g., "my-resource")
# AZURE_OPENAI_API_KEY= # <-- Insert your Azure OpenAI API key here
# AZURE_OPENAI_DEPLOYMENT= # <-- Insert your Azure OpenAI deployment name here (e.g., "gpt-4")
